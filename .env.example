# Supabase — Projekt-URL und Keys
# Projekt-URL findest du im Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Anon/Public Key (sicher für Client-Seite)
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...
# Service Role Key (NUR Server-seitig! NIEMALS im Client verwenden)
SUPABASE_SERVICE_KEY=eyJhbGciOiJI...
# Access Token für Supabase Management API (MCP Server / CLI)
SUPABASE_ACCESS_TOKEN=sbp_...
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# AI — DeepSeek API
# API-Key von https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# AI — ElevenLabs TTS (Vorlesen-Feature)
# Free-Tier: ~10k chars/month. Danach: gpt-4o-mini-tts Fallback.
# API-Key von https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=el_...
# Voice-ID — Chris: warm, ruhig, männlich, deutsch
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# AI — fal.ai Image Generation (FLUX.1 [pro])
# API-Key von https://fal.ai/dashboard/keys
FAL_KEY=...

# Email — Brevo
# API-Key von https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-...
# Verifizierte Absender-Adresse bei Brevo (z.B. newsletter@nureine.de)
BREVO_FROM_EMAIL=newsletter@nureine.de
BREVO_FROM_NAME=NurEine
# Antwort-Adresse (Reply-To) — MUSS ein echtes Postfach sein, sonst bouncen Antworten.
# newsletter@nureine.de hat keinen Maileingang (kein MX/SMTP).
BREVO_REPLY_TO_EMAIL=aaron@example.com

# Admin-Login (Zugang zum /admin Bereich)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ein-sicheres-passwort

# Public Base URL der Website
PUBLIC_BASE_URL=https://nureine.de

# OpenAI API Key (für Edge Function generate-audio — gpt-4o-mini-tts Fallback)
# Wird NUR in Supabase Edge Function Secrets gesetzt, NICHT hier.
# supabase secrets set OPENAI_API_KEY=sk-...

# Newsletter Cron (Cloudflare Worker -> /api/cron/newsletter)
# Shared bearer token. Must be IDENTICAL in:
#   - Vercel env vars (this app)
#   - `wrangler secret put CRON_SECRET` (workers/newsletter-cron)
# Generate: openssl rand -hex 32
CRON_SECRET=replace-with-long-random-hex
ADMIN_SESSION_SECRET=
BREVO_WEBHOOK_SECRET=

# IndexNow — instant index ping to Bing/Yandex on new stories.
# 1. Generate: openssl rand -hex 16
# 2. Set this value AND place an identical file at static/<key>.txt
#    (must be reachable at https://nureine.de/<key>.txt).
# 3. Set in Vercel env vars. The fetch-stories cron pings after each run.
INDEXNOW_KEY=23c37d00926a76325ec657ddf3692e7d

# Threads (Meta) — Auto-Posting. Separates Token vom IG (Scopes threads_basic +
# threads_content_publish). Setup: developers.facebook.com → App → Threads-API.
# Token via OAuth (graph.threads.net/oauth/access_token), Long-Lived (60 Tage).
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=
