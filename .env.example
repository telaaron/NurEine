# Supabase — Projekt-URL und Keys
# Projekt-URL findest du im Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Anon/Public Key (sicher für Client-Seite)
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...
# Service Role Key (NUR Server-seitig! NIEMALS im Client verwenden)
SUPABASE_SERVICE_KEY=eyJhbGciOiJI...
# Access Token für Supabase Management API (MCP Server / CLI)
SUPABASE_ACCESS_TOKEN=sbp_...
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# AI — DeepSeek API
# API-Key von https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# Email — Resend
# API-Key von https://resend.com/api-keys
RESEND_API_KEY=re_...
# Verifizierte Absender-Domain bei Resend (z.B. newsletter@nureine.de)
RESEND_FROM_EMAIL=newsletter@nureine.de

# Admin-Login (Zugang zum /admin Bereich)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ein-sicheres-passwort

# Public Base URL der Website
PUBLIC_BASE_URL=https://nureine.de
