node_modules

# Output
.output
.vercel
.netlify
.wrangler
/.svelte-kit
/build

# Test artifacts
/test-output

# OS
.DS_Store
Thumbs.db

# Env
.env
.env.*
!.env.example
!.env.test

# Mac-Mini-Runner (ops/) — Secrets & echte Agenten-Prompts nie committen
ops/env.runner
ops/prompts/*.md
!ops/prompts/README.md

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Python
__pycache__/
*.pyc

# local dev tooling + scratch
.claude/launch.json
media/*.png

# Firecrawl search cache (skill scratch)
.firecrawl/

# Capacitor / iOS app build (native project keeps its own ios/.gitignore for
# build output, Pods and copied web assets — committed with the project)
build-app/
.DS_Store
.server.ts.appbak

# Xcode native app user/build cruft
ios-native/**/xcuserdata/
ios-native/**/*.xcuserstate
ios-native/**/DerivedData/

# Agenten-Spool: lokale Zwischenablage, wenn Supabase/Storage hakt (Quota, Sperre,
# Offline). Die Agenten arbeiten weiter und parken ihr Ergebnis hier; der
# Nachtrag-Lauf lädt es später hoch. Gehört NIE ins Repo (Binärdaten, flüchtig).
.agent-spool/*
# ...aber README + Ordner-Gerüst gehören ins Repo (sonst kennt kein Agent das Schema)
!.agent-spool/README.md
!.agent-spool/.gitkeep
